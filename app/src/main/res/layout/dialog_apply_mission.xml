<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_bottom_sheet"
    android:backgroundTint="#FFFFFF"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:background="#D1D1D1"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Подать заявку"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/etApplyFirstName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="Имя"
            android:textColor="#9F9F9F"
            android:textColorHint="#9F9F9F"
            android:background="@drawable/edittext_bg"
            android:paddingStart="16dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etApplyLastName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="Фамилия"
            android:textColor="#9F9F9F"
            android:textColorHint="#9F9F9F"
            android:background="@drawable/edittext_bg"
            android:paddingStart="16dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="10"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etApplyAge"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="3"
                android:hint="Лет"
                android:inputType="number"
                android:textColor="#9F9F9F"
                android:textColorHint="#9F9F9F"
                android:background="@drawable/edittext_bg"
                android:paddingStart="16dp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etApplyEmail"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="7"
                android:hint="Ваш Email"
                android:inputType="textEmailAddress"
                android:textColor="#9F9F9F"
                android:textColorHint="#9F9F9F"
                android:background="@drawable/edittext_bg"
                android:paddingStart="16dp"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etApplyReason"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:hint="Почему вы хотите участвовать?"
            android:gravity="top"
            android:padding="16dp"
            android:textColor="#9F9F9F"
            android:textColorHint="#9F9F9F"
            android:background="@drawable/edittext_bg"
            android:layout_marginBottom="24dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSubmitApplication"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Отправить организатору"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_button_bg"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="17sp"/>

    </LinearLayout>
</ScrollView>