<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/rounded_bottom_sheet">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvMissionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Помощь в приюте"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"/>

    <TextView
        android:id="@+id/tvMissionOrg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Организация: Лапа Помощи"
        android:textColor="#7E57C2"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvMissionDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Нам нужны волонтеры для выгула собак и уборки вольеров. Приходи, будет весело и полезно!"
        android:textColor="#444444"
        android:lineSpacingExtra="4dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnApply"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Откликнуться"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_main_gradient" />

</LinearLayout>